{
    "name": "autotasker",
    "version": "0.0.0",
    "main": "dist-electron/main.js",
    "scripts": {
        "start": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
        "dev:react": "cd frontend && npm run dev",
        "dev:electron": "set NODE_ENV=development&& tsc && wait-on http://localhost:5173 && electron .",
        "build:electron": "tsc",
        "build": "npm run build:electron && cd frontend && npm run build && cd .. && npx electron-builder"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "electron": "^26.6.0",
        "typescript": "^5.3.0",
        "@types/node": "^20.10.0",
        "wait-on": "^9.0.5",
        "electron-builder": "^24.6.0"
    },
    "build": {
        "appId": "com.yourname.autotasker",
        "files": [
            "dist-electron/**/*",
            "frontend/dist/**/*",
            "node_modules/**/*",
            "package.json"
        ],
        "directories": {
            "buildResources": "assets"
        },
        "win": {
            "icon": "assets/icons/app.webp",
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "assets/icons/app.ico",
            "uninstallerIcon": "assets/icons/app.ico",
            "installerHeaderIcon": "assets/icons/app.ico",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    }
}
